# Server Configuration
NODE_ENV=development
PORT=5000

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=https://your-firebase-project-id.firebaseio.com

# Supabase Configuration (Optional - if using instead of Firestore)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/gym_trainer

# JWT Secret (for token generation if needed)
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Payment Configuration (Stripe/PayPal)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# API Configuration
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:8080
